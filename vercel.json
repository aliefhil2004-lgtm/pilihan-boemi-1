{
  "functions": {
    "api/roboflow.ts": {
      "maxDuration": 60
    },
    "api/reverse-geocode.ts": {
      "maxDuration": 15
    },
    "api/route.ts": {
      "maxDuration": 15
    },
    "api/incidents.ts": {
      "maxDuration": 30
    },
    "api/nlp.ts": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/((?!api/|assets/).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|assets/).*)",
      "destination": "/index.html"
    }
  ]
}
