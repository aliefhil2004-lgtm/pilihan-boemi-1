ROBOFLOW_API_KEY=
ROBOFLOW_WORKFLOW_URL=https://serverless.roboflow.com/alifs-workspace-qfrwz/workflows/custom-workflow-2

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
# Optional. ResponAI's no-cost prototype stores sanitized thumbnails in Firestore.
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Admin service account JSON for Vercel Incident Management API
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional Hugging Face Space endpoint. Prefer this if you upload huggingface-nlp/ as a Space.
HF_NLP_API_URL=

# Optional direct Hugging Face Inference API fallback when HF_NLP_API_URL is not set.
HUGGINGFACE_API_KEY=
HF_NLP_MODEL=joeddav/xlm-roberta-large-xnli

# Optional TomTom Traffic API key for live road traffic overlay on the emergency map
VITE_TOMTOM_API_KEY=
